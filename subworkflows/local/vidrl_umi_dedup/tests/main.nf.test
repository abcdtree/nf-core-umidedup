// TODO nf-core: Once you have added the required tests, please run the following command to build this file:
// nf-core subworkflows test vidrl_umi_dedup
nextflow_workflow {

    name "Test VIDRL_UMI_DEDUP"
    script "../main.nf"
    config "./nextflow.config"

    workflow "VIDRL_UMI_DEDUP"

    test("Should align paired-end reads and group by UMI") {

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false ],
                    [
                        file("${projectDir}/tests/data/fastq/test_R1.fastq.gz", checkIfExists: true),
                        file("${projectDir}/tests/data/fastq/test_R2.fastq.gz", checkIfExists: true)
                    ]
                ])

                input[1] = Channel.of([
                    [ id: 'genome' ],
                    file("${projectDir}/tests/data/ref/ref.fasta", checkIfExists: true)
                ])
                """
            }
        }

        then {
            assert workflow.success
            assertAll(
                { assert snapshot(workflow.out).match() }
            )
        }
    }
}
